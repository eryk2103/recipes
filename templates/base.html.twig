<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Welcome!{% endblock %}</title>
    <link rel="icon"
          href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
    <link
        href="https://fonts.googleapis.com/css2?family=Spectral:ital,wght@0,400;0,500;0,600;1,400;1,500&family=DM+Mono:wght@400;500&display=swap"
        rel="stylesheet"/>
    <link rel="stylesheet" href="{{ asset('css/styles.css') }}">
    {% block stylesheets %}
    {% endblock %}

    {% block javascripts %}
    {% endblock %}

    {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
    {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
    {% endif %}
</head>
<body>
<header class="site-header">
    <div class="site-header__inner container">
        <button class="brand" type="button"><span class="brand__name">Mise</span><span class="brand__dot"></span>
        </button>
        <nav class="nav">
            <a class="nav__link {% if app.current_route == 'app_recipe_discover'%}nav__link--active{% endif %}" href="{{ path('app_recipe_discover') }}">Discover</a>
            {% if app.user %}
                <a class="nav__link {% if app.current_route == 'app_recipe_index'%}nav__link--active{% endif %}" href="{{ path('app_recipe_index') }}">My Recipes</a>
            {% endif %}
        </nav>
        {% if app.user %}
            {% set _notifications = notifications() %}
            {% set _unread = unread_notification_count() %}
            {# _unread is derived from _notifications in NotificationExtension — single DB query #}
            <div class="nav-actions">
                <a class="btn btn--primary" href="{{ path('app_recipe_new') }}">+ New recipe</a>

                <div class="bell-menu" id="bell-menu">
                    <button class="bell-btn" id="bell-btn" aria-label="Notifications" type="button">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                            <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                        </svg>
                        {% if _unread > 0 %}
                            <span class="bell-badge">{{ _unread > 9 ? '9+' : _unread }}</span>
                        {% endif %}
                    </button>
                    <div class="bell-dropdown" id="bell-dropdown">
                        <div class="bell-dropdown__header">Notifications</div>
                        <div class="bell-dropdown__list">
                            {% if _notifications is empty %}
                                <div class="bell-dropdown__empty">No notifications yet.</div>
                            {% else %}
                                {% for n in _notifications %}
                                    <form method="post" action="{{ path('app_notification_read', {id: n.id}) }}" class="form--contents">
                                        <input type="hidden" name="_token" value="{{ csrf_token('notification-read') }}">
                                        <button type="submit" class="bell-item {% if not n.isRead %}bell-item--unread{% endif %}">
                                            <span class="avatar avatar--sm">{{ n.actor.username|slice(0, 2)|upper }}</span>
                                            <div class="bell-item__body">
                                                <span class="bell-item__text">
                                                    <strong>{{ n.actor.username }}</strong>
                                                    {% if n.type == 'comment' %}commented on{% else %}saved{% endif %}
                                                    <em>{{ n.recipe.title }}</em>
                                                </span>
                                                <span class="bell-item__time">{{ n.createdAt|date('M j') }}</span>
                                            </div>
                                        </button>
                                    </form>
                                {% endfor %}
                            {% endif %}
                        </div>
                    </div>
                </div>

                <div class="avatar-menu">
                    <span class="avatar">{{ app.user.username|slice(0, 2)|upper }}</span>
                    <div class="avatar-dropdown">
                        <div class="avatar-dropdown__inner">
                            <a class="avatar-dropdown__item" href="{{ path('app_logout') }}">Log out</a>
                        </div>
                    </div>
                </div>
            </div>
        {% else %}
            <div class="nav-actions">
                <a class="nav__link" href="{{ path('app_login') }}">Log in</a>
                <a class="nav__link" href="{{ path('app_register') }}">Register</a>
            </div>
        {% endif %}
    </div>
</header>
{% block body %}{% endblock %}
<script src="{{ asset('js/bell.js') }}"></script>
</body>
</html>
