{% extends 'base.html.twig' %}
{% block body %}
    <main>
        <div class="page-head">
            <div>
                <div class="label label--accent page-head__label">The Table — shared kitchen</div>
                <h1 class="h1 page-title">Discover</h1>
                <p>Recipes shared by the community — explore, filter, get inspired.</p>
            </div>
            <div class="search-wrapper">
                <label class="search" for="discover-search">
                    <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="var(--faint)" stroke-width="1.8"
                         class="search__icon">
                        <circle cx="11" cy="11" r="7"></circle>
                        <line x1="16.5" y1="16.5" x2="21" y2="21"></line>
                    </svg>
                    <input type="text" id="discover-search" autocomplete="off"
                           placeholder="Filter by ingredient or name — e.g. anchovy, lemon, beans"/>
                </label>
                <div class="autocomplete" id="autocomplete" hidden></div>
            </div>
        </div>

        <div class="chips" id="active-filters" hidden></div>

        {% if recipes is empty %}
            <p class="meta">No public recipes yet.</p>
        {% else %}
            <p class="meta" id="no-results" hidden>No recipes found.</p>

            <div class="grid-3">
                {% for recipe in recipes %}
                    {% set tagNames = [] %}
                    {% for tag in recipe.tags %}
                        {% set tagNames = tagNames|merge([tag.name|lower]) %}
                    {% endfor %}
                    {% set ingredientNames = [] %}
                    {% for ri in recipe.recipeIngredients %}
                        {% set ingredientNames = ingredientNames|merge([ri.ingredient.name|lower]) %}
                    {% endfor %}
                    <article class="recipe-card card card--relative"
                             data-tags="{{ tagNames|join(',') }}"
                             data-ingredients="{{ ingredientNames|join(',') }}">
                        <a href="{{ path('app_recipe_show', {id: recipe.id}) }}"
                           class="card__link-overlay" aria-label="{{ recipe.title }}"></a>
                        {% if recipe.photo %}
                            <div class="card__photo">
                                <img class="" src="{{ asset('uploads/recipe_photos/' ~ recipe.photo) }}"
                                     alt="recipe photo"/>
                                <span class="card__visibility">{{ recipe.isPublic ? 'Public' : 'Private' }}</span>
                            </div>
                        {% else %}
                            <div class="card__photo photo-placeholder">
                                No photo yet
                                <span class="card__visibility">{{ recipe.isPublic ? 'Public' : 'Private' }}</span>
                            </div>
                        {% endif %}
                        <div class="card__body">
                            {% if recipe.tags is not empty %}
                                <div class="card__tags">
                                    {% for tag in recipe.tags %}
                                        <span class="tag">{{ tag.name }}</span>
                                    {% endfor %}
                                </div>
                            {% endif %}
                            <h3 class="h2">{{ recipe.title }}</h3>
                            <div class="card__author">
                                <span class="avatar avatar--sm">{{ recipe.author.username|slice(0, 2)|upper }}</span>
                                <span class="card__author-name">{{ recipe.author.username }}</span>
                            </div>
                            <div class="card__stats">
                                <span class="stat">{{ recipe.recipeIngredients|length }} ingredients</span>
                                <span class="stat">{{ recipe.steps|length }} steps</span>
                                <span class="spacer"></span>
                                <span class="time">{{ recipe.cookTimeMinutes ?? '—' }} min</span>
                            </div>
                        </div>
                    </article>
                {% endfor %}
            </div>
        {% endif %}
    </main>

    <script src="{{ asset('js/discover.js') }}"></script>
{% endblock %}
