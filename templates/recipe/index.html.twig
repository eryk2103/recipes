{% extends 'base.html.twig' %}
{% block body %}
    <main>
        <div class="page-head">
            <div>
                <div class="label label--accent" style="margin-bottom:12px;">Your recipe box</div>
                <h1 class="h1 page-title">My Recipes</h1>
                <p>Dishes you've written down — drafts and shared, all in one place.</p>
            </div>
        </div>

        {% if recipes is empty %}
            <p class="meta">You haven't added any recipes yet.</p>
        {% else %}
            <nav class="subnav">
                <a href="{{ path('app_recipe_index') }}" class="chip {{ filter == 'all' ? 'chip--active' : '' }}">All · {{ totalCount }}</a>
                <a href="{{ path('app_recipe_index', {filter: 'public'}) }}" class="chip {{ filter == 'public' ? 'chip--active' : '' }}">Public · {{ publicCount }}</a>
                <a href="{{ path('app_recipe_index', {filter: 'private'}) }}" class="chip {{ filter == 'private' ? 'chip--active' : '' }}">Private · {{ privateCount }}</a>
            </nav>

            <div class="grid-3">
                {% for recipe in recipes %}
                    <article class="card" style="position: relative;">
                        <a href="{{ path('app_recipe_show', {id: recipe.id}) }}" style="position: absolute; inset: 0; z-index: 1;" aria-label="{{ recipe.title }}"></a>
                        <div class="card__photo photo-placeholder">
                            No photo yet
                            <span class="card__visibility">{{ recipe.isPublic ? 'Public' : 'Private' }}</span>
                        </div>
                        <div class="card__body">
                            {% if recipe.tags is not empty %}
                                <div class="card__tags">
                                    {% for tag in recipe.tags %}
                                        <span class="tag">{{ tag.name }}</span>
                                    {% endfor %}
                                </div>
                            {% endif %}
                            <h3 class="h2">{{ recipe.title }}</h3>
                            <div class="card__author">
                                <span class="avatar avatar--sm">{{ recipe.author.username|slice(0, 2)|upper }}</span>
                                <span class="card__author-name">You</span>
                                <a class="btn btn--ghost btn--sm" href="{{ path('app_recipe_edit', {id: recipe.id}) }}" style="position: relative; z-index: 2;">Edit</a>
                            </div>
                            <div class="card__stats">
                                <span class="stat">{{ recipe.recipeIngredients|length }} ingredients</span>
                                <span class="stat">{{ recipe.steps|length }} steps</span>
                                <span class="spacer"></span>
                                <span class="time">{{ recipe.cookTimeMinutes ?? '—' }} min</span>
                            </div>
                        </div>
                    </article>
                {% endfor %}
            </div>
        {% endif %}
    </main>
{% endblock %}
