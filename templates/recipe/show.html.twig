{% extends 'base.html.twig' %}
{% block stylesheets %}
    <style>
        .detail-bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 16px;
            margin-bottom: 14px;
        }

        .ingredient-list-view {
            list-style: none;
            margin: 0;
            padding: 0;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .ingredient-list-view li {
            display: flex;
            gap: 10px;
            padding-bottom: 10px;
            border-bottom: 1px solid var(--line);
            font-size: 14px;
        }

        .ingredient-amount {
            font-family: var(--font-mono);
            color: var(--muted);
            min-width: 70px;
            flex-shrink: 0;
        }

        .step-list-view {
            display: flex;
            flex-direction: column;
            gap: 28px;
        }

        .method-label {
            margin: var(--space-7) 0 var(--space-5);
        }

        .detail-photo {
            width: 100%;
            height: 360px;
            border-radius: var(--radius-lg);
            margin-bottom: var(--space-7);
        }
    </style>
{% endblock %}
{% block body %}
    <main>
        <div class="detail-bar">
            <a class="nav__link" href="{{ path('app_recipe_index') }}">← My Recipes</a>
            <a class="btn btn--primary" href="{{ path('app_recipe_edit', {id: recipe.id}) }}">Edit recipe</a>
        </div>

        <div class="page-head">
            {% if recipe.tags is not empty %}
                <div class="card__tags" style="margin-bottom: 12px;">
                    {% for tag in recipe.tags %}
                        <span class="tag">{{ tag.name }}</span>
                    {% endfor %}
                </div>
            {% endif %}
            <h1 class="display page-title">{{ recipe.title }}</h1>
            <div class="meta" style="display: flex; align-items: center; gap: 10px;">
                <span class="card__author">
                    <span class="avatar avatar--sm">{{ recipe.author.username|slice(0, 2)|upper }}</span>
                    <span class="card__author-name" style="font-size: 16px; font-weight: 500; color: var(--ink);">{{ recipe.author.username }}</span>
                </span>
                <span>·</span>
                <span>
                    {% if recipe.servings %}{{ recipe.servings }} servings{% endif %}
                    {% if recipe.cookTimeMinutes %} · {{ recipe.cookTimeMinutes }} min{% endif %}
                </span>
            </div>
        </div>

        <div class="card__photo photo-placeholder detail-photo">No photo yet</div>

        <div class="recipe-layout">
            <aside>
                <div class="label" style="margin-bottom: var(--space-3);">Ingredients</div>
                <ul class="ingredient-list-view">
                    {% for ingredient in recipe.recipeIngredients %}
                        <li>
                            <span class="ingredient-amount">{{ ingredient.amount }} {{ ingredient.unit.value }}</span>
                            <span>{{ ingredient.ingredient.name }}</span>
                        </li>
                    {% endfor %}
                </ul>
            </aside>

            <div>
                {% if recipe.notes %}
                    <p class="lede">{{ recipe.notes }}</p>
                {% endif %}

                <div class="label method-label">Method</div>
                <div class="step-list-view">
                    {% for step in recipe.steps %}
                        <div class="step">
                            <div class="step__n">{{ loop.index }}</div>
                            <p class="step__text">{{ step.instruction }}</p>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    </main>
{% endblock %}
